{
  "name": "singularity-ai-club",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "sync:instagram": "node scripts/sync-instagram-feed.mjs",
    "validate:site": "node scripts/validate-site-output.mjs",
    "predev": "npm run sync:instagram",
    "prebuild": "npm run sync:instagram",
    "dev": "vite --open /site.html",
    "build": "vite build && node scripts/publish-root.mjs && npm run validate:site",
    "preview": "vite preview --open /site.html",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.363.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^5.4.0"
  }
}
